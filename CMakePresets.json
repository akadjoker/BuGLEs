{
  "version": 3,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 20,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "release-base",
      "hidden": true,
      "generator": "Ninja",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "BUGL_PORTABLE_RELEASE": "ON",
        "BUGL_STRIP_RELEASE": "ON",
        "BUGL_ENABLE_COMPILER_CACHE": "ON"
      }
    },
    {
      "name": "debug-base",
      "hidden": true,
      "generator": "Ninja",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "BUGL_PORTABLE_RELEASE": "ON",
        "BUGL_STRIP_RELEASE": "OFF",
        "BUGL_ENABLE_COMPILER_CACHE": "ON"
      }
    },
    {
      "name": "linux-release",
      "inherits": "release-base",
      "binaryDir": "${sourceDir}/build-release"
    },
    {
      "name": "linux-debug",
      "inherits": "debug-base",
      "binaryDir": "${sourceDir}/build-debug"
    },
    {
      "name": "win64-release",
      "inherits": "release-base",
      "binaryDir": "${sourceDir}/build-win64-release",
      "cacheVariables": {
        "CMAKE_TOOLCHAIN_FILE": "${sourceDir}/mingw-w64.cmake"
      }
    },
    {
      "name": "win64-debug",
      "inherits": "debug-base",
      "binaryDir": "${sourceDir}/build-win64-debug",
      "cacheVariables": {
        "CMAKE_TOOLCHAIN_FILE": "${sourceDir}/mingw-w64.cmake"
      }
    },
    {
      "name": "msvc-debug",
      "generator": "Visual Studio 17 2022",
      "architecture": "x64",
      "binaryDir": "${sourceDir}/build-msvc-debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "BUGL_PORTABLE_RELEASE": "ON",
        "BUGL_STRIP_RELEASE": "OFF",
        "BUGL_ENABLE_COMPILER_CACHE": "OFF"
      }
    },
    {
      "name": "msvc-release",
      "generator": "Visual Studio 17 2022",
      "architecture": "x64",
      "binaryDir": "${sourceDir}/build-msvc-release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "BUGL_PORTABLE_RELEASE": "ON",
        "BUGL_STRIP_RELEASE": "ON",
        "BUGL_ENABLE_COMPILER_CACHE": "OFF"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "linux-release",
      "configurePreset": "linux-release"
    },
    {
      "name": "linux-debug",
      "configurePreset": "linux-debug"
    },
    {
      "name": "win64-release",
      "configurePreset": "win64-release"
    },
    {
      "name": "win64-debug",
      "configurePreset": "win64-debug"
    },
    {
      "name": "msvc-debug",
      "configurePreset": "msvc-debug",
      "configuration": "Debug"
    },
    {
      "name": "msvc-release",
      "configurePreset": "msvc-release",
      "configuration": "Release"
    }
  ]
}
