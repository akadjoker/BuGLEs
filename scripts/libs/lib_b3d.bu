    //otimize
    def update(aframe)
    {
    if (!self.ready) return;

    // 1 — anima joints
    for (var i = 0; i < len(self.joints); i += 1)
    {
        var j = self.joints[i];
        j.buildLocalMatrix(aframe);
        if (j.parentIndex < 0)
            j.globalMat = j.localMat;
        else
            j.globalMat = MatrixMultiply(j.localMat, self.joints[j.parentIndex].globalMat);
        j.skinMat = MatrixMultiply(j.offsetMat, j.globalMat);
    }

        // 2 — cache skinMats num array local (evita double-dereference por vértice)
    self.skinMats.clear();
    for (var i = 0; i < len(self.joints); i += 1)
        self.skinMats.push(self.joints[i].skinMat);

    // 3 — skin vertices
    for (var si = 0; si < len(self.surfaces); si += 1)
    {
        var surf = self.surfaces[si];
        var verts = surf.vertices;
        var skin  = surf.skinned;
        var nv    = len(verts);

        for (var vi = 0; vi < nv; vi += 1)
        {
            var src = verts[vi];
            var dst = skin[vi];

            if (src.b0 < 0)
            {
                dst.x=src.x; dst.y=src.y; dst.z=src.z;
                dst.nx=src.nx; dst.ny=src.ny; dst.nz=src.nz;
                continue;
            }

            var ox=0.0; var oy=0.0; var oz=0.0;
            var onx=0.0; var ony=0.0; var onz=0.0;
            var sm;

            if (src.b0 >= 0 && src.w0 > 0.0) 
            {
                sm=self.skinMats[src.b0];
                ox +=(sm.m0*src.x+sm.m4*src.y+sm.m8 *src.z+sm.m12)*src.w0;
                oy +=(sm.m1*src.x+sm.m5*src.y+sm.m9 *src.z+sm.m13)*src.w0;
                oz +=(sm.m2*src.x+sm.m6*src.y+sm.m10*src.z+sm.m14)*src.w0;
                onx+=(sm.m0*src.nx+sm.m4*src.ny+sm.m8 *src.nz)*src.w0;
                ony+=(sm.m1*src.nx+sm.m5*src.ny+sm.m9 *src.nz)*src.w0;
                onz+=(sm.m2*src.nx+sm.m6*src.ny+sm.m10*src.nz)*src.w0;
            }
            if (src.b1 >= 0 && src.w1 > 0.0) 
            {
                sm=self.skinMats[src.b1];
                ox +=(sm.m0*src.x+sm.m4*src.y+sm.m8 *src.z+sm.m12)*src.w1;
                oy +=(sm.m1*src.x+sm.m5*src.y+sm.m9 *src.z+sm.m13)*src.w1;
                oz +=(sm.m2*src.x+sm.m6*src.y+sm.m10*src.z+sm.m14)*src.w1;
                onx+=(sm.m0*src.nx+sm.m4*src.ny+sm.m8 *src.nz)*src.w1;
                ony+=(sm.m1*src.nx+sm.m5*src.ny+sm.m9 *src.nz)*src.w1;
                onz+=(sm.m2*src.nx+sm.m6*src.ny+sm.m10*src.nz)*src.w1;
            }
            if (src.b2 >= 0 && src.w2 > 0.0) 
            {
                sm=self.skinMats[src.b2];
                ox +=(sm.m0*src.x+sm.m4*src.y+sm.m8 *src.z+sm.m12)*src.w2;
                oy +=(sm.m1*src.x+sm.m5*src.y+sm.m9 *src.z+sm.m13)*src.w2;
                oz +=(sm.m2*src.x+sm.m6*src.y+sm.m10*src.z+sm.m14)*src.w2;
                onx+=(sm.m0*src.nx+sm.m4*src.ny+sm.m8 *src.nz)*src.w2;
                ony+=(sm.m1*src.nx+sm.m5*src.ny+sm.m9 *src.nz)*src.w2;
                onz+=(sm.m2*src.nx+sm.m6*src.ny+sm.m10*src.nz)*src.w2;
            }
            if (src.b3 >= 0 && src.w3 > 0.0) 
            {
                sm=self.skinMats[src.b3];
                ox +=(sm.m0*src.x+sm.m4*src.y+sm.m8 *src.z+sm.m12)*src.w3;
                oy +=(sm.m1*src.x+sm.m5*src.y+sm.m9 *src.z+sm.m13)*src.w3;
                oz +=(sm.m2*src.x+sm.m6*src.y+sm.m10*src.z+sm.m14)*src.w3;
                onx+=(sm.m0*src.nx+sm.m4*src.ny+sm.m8 *src.nz)*src.w3;
                ony+=(sm.m1*src.nx+sm.m5*src.ny+sm.m9 *src.nz)*src.w3;
                onz+=(sm.m2*src.nx+sm.m6*src.ny+sm.m10*src.nz)*src.w3;
            }

            dst.x=ox; dst.y=oy; dst.z=oz;
            dst.nx=onx; dst.ny=ony; dst.nz=onz;
        }
    }
}

    // ----------------------------------------------------------
    // Draw
    // ----------------------------------------------------------

    def draw()
    {
        if (!self.ready) return;

        rlPushMatrix();
        rlTranslatef(self.posX, self.posY, self.posZ);
        rlRotatef(self.rotX, 1.0, 0.0, 0.0);
        rlRotatef(self.rotY, 0.0, 1.0, 0.0);
        rlRotatef(self.rotZ, 0.0, 0.0, 1.0);
        rlScalef(self.scaleVal, self.scaleVal, self.scaleVal);

        for (var si = 0; si < len(self.surfaces); si += 1)
            self.drawSurface(self.surfaces[si]);

        if (self.showSkeleton)
            self.drawSkeleton();

        rlPopMatrix();
    }

    def drawSurface(surf)
    {
        if (surf.texId > 0) rlEnableTexture(surf.texId);
        else rlDisableTexture();

        rlColor4f(1.0, 1.0, 1.0, 1.0);
        rlBegin(RL_TRIANGLES);
        for (var i = 0; i < len(surf.indices); i += 1)
        {
            var idx = surf.indices[i];
            var vt  = surf.skinned[idx];
            rlNormal3f(vt.nx, vt.ny, vt.nz);
            rlTexCoord2f(vt.u, vt.v);
            rlColor4f(vt.r, vt.g, vt.b, vt.a);
            rlVertex3f(vt.x, vt.y, vt.z);
        }
        rlEnd();

        rlDisableTexture();
        rlColor4f(1.0, 1.0, 1.0, 1.0);
    }

    // ----------------------------------------------------------
    // Stats
    // ----------------------------------------------------------

    def jointCount()   { return len(self.joints); }
    def surfaceCount() { return len(self.surfaces); }
    def triangleCount()
    {
        var total = 0;
        for (var i = 0; i < len(self.surfaces); i += 1)
            total += len(self.surfaces[i].indices) / 3;
        return total;
    }

    def drawSkeleton()
    {
        if (!self.ready) return;

        rlDisableTexture();
        rlDisableDepthTest();
        rlSetLineWidth(0.5);

        for (var i = 0; i < len(self.joints); i += 1)
        {
            var j = self.joints[i];

            // posição world do joint (coluna de translação da globalMat)
            var jx = j.globalMat.m12;
            var jy = j.globalMat.m13;
            var jz = j.globalMat.m14;

            // linha ao pai
            if (j.parentIndex >= 0)
            {
                var p = self.joints[j.parentIndex];
                var px = p.globalMat.m12;
                var py = p.globalMat.m13;
                var pz = p.globalMat.m14;

                rlBegin(RL_LINES);
                rlColor3f(1.0, 1.0, 0.0);
                rlVertex3f(px, py, pz);
                rlVertex3f(jx, jy, jz);
                rlEnd();
            }

            // eixos locais (X=vermelho, Y=verde, Z=azul)
            var s = 0.5;
            var m = j.globalMat;
            rlBegin(RL_LINES);
            rlColor3f(1.0, 0.2, 0.2);
            rlVertex3f(jx, jy, jz);
            rlVertex3f(jx + m.m0*s, jy + m.m1*s, jz + m.m2*s);
            rlColor3f(0.2, 1.0, 0.2);
            rlVertex3f(jx, jy, jz);
            rlVertex3f(jx + m.m4*s, jy + m.m5*s, jz + m.m6*s);
            rlColor3f(0.2, 0.5, 1.0);
            rlVertex3f(jx, jy, jz);
            rlVertex3f(jx + m.m8*s, jy + m.m9*s, jz + m.m10*s);

            // marca visual do joint (cruz curta em vez de GL_POINTS)
            var p = 0.05;
            rlColor3f(1.0, 0.9, 0.1);
            rlVertex3f(jx - p, jy, jz);
            rlVertex3f(jx + p, jy, jz);
            rlVertex3f(jx, jy - p, jz);
            rlVertex3f(jx, jy + p, jz);
            rlVertex3f(jx, jy, jz - p);
            rlVertex3f(jx, jy, jz + p);
            rlEnd();
        }

        rlSetLineWidth(1.0);
        rlEnableDepthTest();
        rlDisableTexture();
    }
}
